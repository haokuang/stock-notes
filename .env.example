# 使用说明
# 1. 复制本文件为 .env.local。
# 2. 通常只需填写“基础启动必需”；其他变量仅在启用对应功能时填写。
# 3. 带默认值的变量可不写入 .env.local，代码会自动使用这里标注的默认值。
# 4. 生产环境请复制 .env.production.example 为 .env.production；不要提交真实密钥文件。

# ============================================================
# 1. 基础启动必需：Supabase Auth + API + Postgres
# ============================================================

# Supabase 项目 URL、前端公开 anon key、仅后端使用的 service role key
# 注意：anon key 后端微信登录也需要（verifyOtp 换 session 用 anon 客户端）
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 数据库凭据三选一：优先级 DATABASE_URL > SUPABASE_DB_URL > SUPABASE_DB_PASSWORD。
# 阿里云 RDS Supabase / 其他实例推荐使用完整 PostgreSQL 连接串 DATABASE_URL 或 SUPABASE_DB_URL。
DATABASE_URL=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_URL=

# 可省略，默认 pooler-transaction；临时表集成测试使用 pooler-session。
DB_CONNECTION_PROFILE=pooler-transaction

# 可省略，默认 true；当 RDS 返回 “server does not support SSL connections” 时设为 false。
DATABASE_SSL=true

# ============================================================
# 2. 本地开发可选：不配置也能使用标准 H5 登录流程
# ============================================================

# H5 留空时使用相对 /api + Vite proxy；微信小程序生产构建必须填写真实 HTTPS API 域名。
PROJECT_DOMAIN=

# 可省略，H5 开发代理默认 http://localhost:3000；Docker 开发环境会自动覆盖。
H5_PROXY_TARGET=

# 无 Authorization JWT 时的本地兼容用户；正常登录流程不需要。
DEFAULT_USER_ID=

# 仅开发环境显示测试登录入口；生产构建会自动清空并隐藏入口。
TEST_LOGIN_EMAIL=
TEST_LOGIN_PASSWORD=

# ============================================================
# 3. 功能可选：不使用对应功能时整组留空
# ============================================================

# A 股行情、股票搜索与价格历史
TUSHARE_TOKEN=

# DeepSeek：每日简报与 Stock Agent 需要 API Key。
# base URL / flash / pro / agent 模型已写死在代码常量,无需配置。
DEEPSEEK_API_KEY=

# Stock Agent：OpenAI provider（两项需同时配置）
OPENAI_API_KEY=
AGENT_OPENAI_MODEL=

# Stock Agent：MiniMax provider
# MINIMAX_CREDENTIAL_MODE 可选 api 或 coding_plan；只填写所选模式对应的一组凭据。
# base URL(api 模式)与模型已写死在代码常量,无需配置；coding_plan 模式下需配置 CODING_PLAN_BASE_URL。
MINIMAX_CREDENTIAL_MODE=api
MINIMAX_API_KEY=
MINIMAX_CODING_PLAN_API_KEY=
MINIMAX_CODING_PLAN_BASE_URL=

# Agent 联网检索：通过 MiniMax CLI 执行 `mmx search query`。
# 默认共用 MINIMAX_API_KEY；留空时 Agent 仍可运行，但新闻检索工具不可用。
# MINIMAX_CLI_PATH 默认留空，会自动使用项目依赖中的 mmx-cli；仅需指定自定义 mmx 路径时填写。
# MINIMAX_REGION 可选 cn/global。
# MINIMAX_CLI_BASE_URL 可覆盖 CLI 搜索地址；不填时复用并自动规整 MINIMAX_BASE_URL。
MINIMAX_CLI_BASE_URL=
MINIMAX_CLI_PATH=
MINIMAX_REGION=

# 图片 AI 分析：三项需同时配置。
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=

# TOS / S3 兼容图片上传：除 AWS_REGION 外四项需同时配置。
COZE_BUCKET_ENDPOINT_URL=
COZE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=cn-beijing

# 错误邮件告警：不配置 RESEND_API_KEY / ALERT_EMAIL 时只记录日志，不发邮件。
RESEND_API_KEY=
ALERT_EMAIL=
ALERT_FROM_EMAIL=alerts@stock-notes.local

# 微信小程序登录：code2session 换 openid（仅后端使用，不可泄露）
# AppID 与 project.config.json 中的一致；AppSecret 从微信后台「开发设置」获取。
WECHAT_APPID=
WECHAT_SECRET=

# ============================================================
# 4. Agent Worker 运行调优：全部可省略，以下为默认值
# ============================================================

AGENT_WORKER_CONCURRENCY=2
AGENT_WORKER_POLL_MS=1000
AGENT_WORKER_HEARTBEAT_MS=15000
AGENT_RUN_LEASE_MS=45000

# ============================================================
# 5. 生产 / Docker / 构建专用：本地 .env.local 通常不需要
# ============================================================

# Docker 生产环境对外端口，默认 8080。
APP_PORT=8080

# 微信小程序 AppID；仅构建/CI 配置需要。
TARO_APP_WEAPP_APPID=

# 抖音 Docker 支持已取消；以下仅保留给现有非 Docker 构建/CI。
TARO_APP_TT_APPID=
TARO_APP_TT_EMAIL=
TARO_APP_TT_PASSWORD=

# Supabase 管理 API / CLI / MCP 使用，不是应用启动变量。
SUPABASE_ACCESS_TOKEN=
